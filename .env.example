APP_ENV=dev
APP_SECRET_KEY=replace-with-a-long-random-string
JWT_EXPIRE_MINUTES=1440
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5175

DATABASE_URL=postgresql+psycopg://opsagent:opsagent_password@postgres:5432/ops_agent_chat

LLM_API_KEY=replace-with-your-model-api-key
LLM_BASE_URL=https://api.deepseek.com
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-v4-pro
LLM_ALLOWED_BASE_URLS=https://api.deepseek.com,https://api.openai.com/v1
# Optional. When empty, APP_SECRET_KEY derives the encryption key for user model credentials.
LLM_CREDENTIAL_ENCRYPTION_KEY=
LLM_REASONING_EFFORT=high
LLM_THINKING_ENABLED=true
LLM_TIMEOUT_SECONDS=90
AGENT_TIMEOUT_SECONDS=300
AGENT_CONTEXT_MAX_CHARS=60000
MONITOR_INTERVAL_SECONDS=15

ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-before-running
REGISTRATION_ENABLED=true
# 开发环境可留空；生产环境开放注册时必须设置至少 16 位的随机注册码
REGISTRATION_INVITE_CODE=

VIDEOHUB_PROJECT_NAME=VideoHub
VIDEOHUB_DEPLOY_TYPE=docker_compose
VIDEOHUB_WORKDIR=/home/jcheng/Golang/feedsystem_video_go
VIDEOHUB_COMPOSE_FILE=docker-compose.yml
VIDEOHUB_HEALTH_URL=http://127.0.0.1:8080/health

VIDEOHUB_SSH_HOST=host.docker.internal
VIDEOHUB_SSH_PORT=22
VIDEOHUB_SSH_USERNAME=opsagent
VIDEOHUB_SSH_KEY_HOST_DIR=./secrets
VIDEOHUB_SSH_KEY_PATH=/run/secrets/videohub_ssh_key
VIDEOHUB_SSH_HOST_FINGERPRINT=
SSH_STRICT_HOST_KEY_CHECKING=true
